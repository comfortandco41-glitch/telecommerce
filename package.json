{
  "name": "superbot-backend",
  "version": "0.1.0",
  "description": "Tele-Commerce Multi-Tenant Telegram Shop SaaS Backend",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "build:frontend": "npm run build --prefix dashboard",
    "start": "node dist/src/index.js",
    "dev": "nodemon src/index.ts",
